# ─────────────────────────────────────────────────────────────
# LLM Studio — Environment Configuration
# Copy this file to .env and customize for your deployment.
# ─────────────────────────────────────────────────────────────

# ── Network ──
BIND_IP=0.0.0.0

# ── Local Model Configuration ──
# Path to directory containing GGUF model files on the host
LLAMA_MODELS_DIR=$HOME/.local/share/llama-lab/models
# Path to llama-server binary (mount specific file, not whole dir — prevents shadowing container binaries)
LLAMA_SERVER_PATH=/usr/local/bin/llama-server
# Default model to pre-select in the UI (must exist in MODELS_DIR)
DEFAULT_MODEL=qwen25-coder-7b
# CPU threads for local inference (recommended: nproc - 1 on this server = 11)
MODEL_THREADS=4
# Context window size for local models
MODEL_CONTEXT_SIZE=8192

# ── Agent Configuration ──
DEFAULT_AGENT_TYPE=picoclaw
AGENT_TIMEOUT=86400
AGENT_CPU_LIMIT=4
AGENT_MEMORY_LIMIT=4G

# ── Authentication ──
# JWT secret shared between portal backend and auth-bridge
JWT_SECRET=change-me-in-production
# Open WebUI encryption key
WEBUI_SECRET_KEY=change-me-in-production
# Open WebUI admin API key (for auto-provisioning users)
WEBUI_ADMIN_KEY=

# ── Remote LLM Provider API Keys ──
# These are the standardized names. The gateway also reads DEXTER_* variants
# for compatibility with the hedgefund portal's existing env vars.
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
